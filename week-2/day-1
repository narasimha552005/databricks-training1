--I have created a database to practice SQL using the database images you sent.
--database name college management service


create database cms;

use cms

--department
 create table department(
   dep_id int primary key,
   dep_name varchar(30),
   dep_block_no int
   );

--student
create table student(
   stu_id int primary key,
   stu_name varchar(30),
   age int,
   address varchar(100),
   city varchar,
   dep_id int,
   foreign key (dep_id) references Department(dep_id)
   );

--staff
create table staff(
  staff_id int primary key,
  staff_name varchar(100),
  dep_id int,
  foreign key(dep_id) references Department(dep_id)
  );

--suject
create table subject(
  sub_id int primary key,
  sub_name varchar(20),
  sub_code int,
  staff_id int,
  foreign key (staff_id)
  references Staff(staff_id)
  );
--marks

create table marks(
  result int,
  sub_id INT,
  stu_id INT,

    PRIMARY KEY (sub_id, stu_id),

    FOREIGN KEY (sub_id)
    REFERENCES Subject(sub_id),

    FOREIGN KEY (stu_id)
    REFERENCES Student(stu_id)
    );

