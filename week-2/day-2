-- 1. Display all available cars
SELECT * FROM cars;

-- 2. Show only SUV cars
SELECT * 
FROM cars
WHERE car_type = 'SUV';

-- 3. Show customers from Hyderabad
SELECT *
FROM customers
WHERE address = 'Hyderabad';

-- 4. Find rentals with fare greater than 6000
SELECT *
FROM rentals
WHERE fare_amount > 6000;

-- 5. Display car names and their owners
SELECT c.car_name, o.own_name
FROM cars c
JOIN owners o
ON c.own_id = o.own_id;

-- 6. Show customer name and rented car
SELECT cu.customer_name, ca.car_name
FROM rentals r
JOIN customers cu
ON r.customer_id = cu.customer_id
JOIN cars ca
ON r.car_id = ca.car_id;

-- 7. Find cars not rented
SELECT car_id, car_name
FROM cars
WHERE car_id NOT IN (
    SELECT car_id FROM rentals
);

-- 8. Count total cars
SELECT COUNT(*) AS total_cars
FROM cars;

-- 9. Count total rentals
SELECT COUNT(*) AS total_rentals
FROM rentals;

-- 10. Find maximum fare amount
SELECT MAX(fare_amount) AS highest_fare
FROM rentals;

-- 11. Find minimum fare amount
SELECT MIN(fare_amount) AS lowest_fare
FROM rentals;

-- 12. Find average fare amount
SELECT AVG(fare_amount) AS average_fare
FROM rentals;

-- 13. Show rentals sorted by fare amount descending
SELECT *
FROM rentals
ORDER BY fare_amount DESC;

-- 14. Find total km driven
SELECT SUM(km_driven) AS total_km
FROM rentals;

-- 15. Display customers whose name starts with 'R'
SELECT *
FROM customers
WHERE customer_name LIKE 'R%';

-- 16. Display cars whose name ends with 'a'
SELECT *
FROM cars
WHERE car_name LIKE '%a';

-- 17. Find all hatchback cars
SELECT *
FROM cars
WHERE car_type = 'Hatchback';

-- 18. Show rental details with customer and car names
SELECT r.rental_id,
       cu.customer_name,
       ca.car_name,
       r.pickup_date,
       r.return_date
FROM rentals r
JOIN customers cu
ON r.customer_id = cu.customer_id
JOIN cars ca
ON r.car_id = ca.car_id;

-- 19. Find owner of CAR110
SELECT o.own_name
FROM owners o
JOIN cars c
ON o.own_id = c.own_id
WHERE c.car_id = 'CAR110';

-- 20. Find customers who rented SUV cars
SELECT cu.customer_name, ca.car_name
FROM rentals r
JOIN customers cu
ON r.customer_id = cu.customer_id
JOIN cars ca
ON r.car_id = ca.car_id
