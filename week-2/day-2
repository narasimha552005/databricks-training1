-- 21. Find cars rented after 2025-05-10
SELECT *
FROM rentals
WHERE pickup_date > '2025-05-10';

-- 22. Display cars with fare greater than average fare
SELECT *
FROM rentals
WHERE fare_amount > (
    SELECT AVG(fare_amount)
    FROM rentals
);

-- 23. Find total rentals for each car
SELECT car_id, COUNT(*) AS total_rentals
FROM rentals
GROUP BY car_id;

-- 24. Find total fare collected for each car
SELECT car_id, SUM(fare_amount) AS total_income
FROM rentals
GROUP BY car_id;

-- 25. Find number of cars by type
SELECT car_type, COUNT(*) AS total
FROM cars
GROUP BY car_type;

-- 26. Find customers who never rented cars
SELECT customer_id, customer_name
FROM customers
WHERE customer_id NOT IN (
    SELECT customer_id
    FROM rentals
);

-- 27. Find cars rented between two dates
SELECT *
FROM rentals
WHERE pickup_date BETWEEN '2025-05-01' AND '2025-05-10';

-- 28. Display the highest km driven rental
SELECT *
FROM rentals
WHERE km_driven = (
    SELECT MAX(km_driven)
    FROM rentals
);

-- 29. Find owner and car details
SELECT o.own_name,
       c.car_name,
       c.car_type
FROM owners o
JOIN cars c
ON o.own_id = c.own_id;

-- 30. Find customers whose fare amount is above 7000
SELECT cu.customer_name, r.fare_amount
FROM rentals r
JOIN customers cu
ON r.customer_id = cu.customer_id
WHERE r.fare_amount > 7000;

-- 31. Find second highest fare
SELECT MAX(fare_amount) AS second_highest
FROM rentals
WHERE fare_amount < (
    SELECT MAX(fare_amount)
    FROM rentals
);

-- 32. Display vacant cars using LEFT JOIN
SELECT c.car_id, c.car_name
FROM cars c
LEFT JOIN rentals r
ON c.car_id = r.car_id
WHERE r.car_id IS NULL;

-- 33. Find how many rentals each customer made
SELECT customer_id, COUNT(*) AS rentals_count
FROM rentals
GROUP BY customer_id;

-- 34. Find cars rented more than once
SELECT car_id, COUNT(*) AS total
FROM rentals
GROUP BY car_id
HAVING COUNT(*) > 1;

-- 35. Display all sedan cars not rented
SELECT *
FROM cars
WHERE car_type = 'Sedan'
AND car_id NOT IN (
    SELECT car_id
    FROM rentals
);

